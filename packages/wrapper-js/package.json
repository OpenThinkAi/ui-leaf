{
  "name": "@openthink/ui-leaf-wrapper",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "postinstall": "node ./run-postinstall.cjs",
    "prepack": "node -e \"require('node:fs').copyFileSync('bin/ui-leaf-bin.stub','bin/ui-leaf-bin')\""
  },
  "bin": {
    "ui-leaf": "./bin/ui-leaf"
  },
  "files": [
    "dist",
    "bin",
    "run-postinstall.cjs"
  ],
  "devDependencies": {
    "tsup": "^8.4.0"
  }
}
