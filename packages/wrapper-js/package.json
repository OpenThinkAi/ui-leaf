{
  "name": "@openthink/ui-leaf",
  "version": "1.0.1",
  "description": "Customizable browser views, on demand, for any CLI.",
  "license": "MIT",
  "author": "Matt Pardini",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenThinkAi/ui-leaf.git",
    "directory": "packages/wrapper-js"
  },
  "homepage": "https://github.com/OpenThinkAi/ui-leaf",
  "bugs": "https://github.com/OpenThinkAi/ui-leaf/issues",
  "keywords": [
    "cli",
    "ui",
    "browser",
    "byov",
    "local-first",
    "views",
    "dashboard"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "postinstall": "node ./run-postinstall.cjs",
    "prepack": "node -e \"const fs=require('node:fs');fs.copyFileSync('bin/ui-leaf-bin.stub','bin/ui-leaf-bin');fs.copyFileSync('../../README.md','README.md');fs.copyFileSync('../../LICENSE','LICENSE')\""
  },
  "bin": {
    "ui-leaf": "./bin/ui-leaf"
  },
  "files": [
    "dist",
    "bin",
    "run-postinstall.cjs",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "tsup": "^8.4.0"
  }
}
